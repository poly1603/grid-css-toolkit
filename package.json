{
  "name": "grid-css-toolkit",
  "version": "1.0.0",
  "description": "GridStack.js - CSS Grid 转换工具包：编辑态拖拽排版，预览态纯 CSS Grid 渲染",
  "type": "module",
  "main": "dist/grid-css-toolkit.umd.cjs",
  "module": "dist/grid-css-toolkit.js",
  "types": "dist/types/grid-css-toolkit.d.ts",
  "exports": {
    ".": {
      "import": "./dist/grid-css-toolkit.js",
      "require": "./dist/grid-css-toolkit.umd.cjs",
      "types": "./dist/types/grid-css-toolkit.d.ts"
    },
    "./editor": {
      "import": "./dist/editor.js",
      "require": "./dist/editor.umd.cjs",
      "types": "./dist/types/editor.d.ts"
    },
    "./preview": {
      "import": "./dist/preview.js",
      "require": "./dist/preview.umd.cjs",
      "types": "./dist/types/preview.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve examples/demo --config examples/demo/vite.config.ts",
    "build": "vite build --config vite.config.lib.ts && node -e \"require('fs').copyFileSync('src/style.css','dist/style.css')\"",
    "build:watch": "vite build --config vite.config.lib.ts --watch",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "gridstack",
    "css-grid",
    "layout",
    "drag-drop",
    "visual-editor",
    "grid",
    "responsive"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "lucide": "^0.344.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0",
    "vue-tsc": "^1.8.27"
  },
  "dependencies": {
    "gridstack": "^10.3.0"
  },
  "peerDependencies": {
    "lucide": ">=0.344.0"
  },
  "peerDependenciesMeta": {
    "lucide": {
      "optional": true
    }
  }
}
